# Discord Rich Presence Application ID
DISCORD_CLIENT_ID=your_discord_application_id_here

# BOINC RPC connection settings
BOINC_HOST=127.0.0.1
BOINC_PORT=31416

# Path to BOINC RPC password file
# Linux default:
BOINC_PASSWORD_PATH=/var/lib/boinc/gui_rpc_auth.cfg

# Windows example (uncomment if needed):
# BOINC_PASSWORD_PATH=C:\ProgramData\BOINC\gui_rpc_auth.cfg

# Update interval (seconds)
UPDATE_INTERVAL=15

# Enable debug logs (True / False)
DEBUG_MODE=False
